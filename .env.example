ADHERENCE_ENV=dev
ADHERENCE_LOG_LEVEL=INFO
ADHERENCE_API_HOST=0.0.0.0
ADHERENCE_API_PORT=7421

# Auth
ADHERENCE_JWT_SECRET=change-me-please-32-bytes-min-xxxxxxxx
ADHERENCE_JWT_ALG=HS256
ADHERENCE_JWT_TTL_SECONDS=3600
ADHERENCE_API_KEYS=admin:adm_devkey_replace,service:svc_devkey_replace,viewer:vwr_devkey_replace

# Storage
ADHERENCE_DB_URL=postgresql+psycopg://adherence:adherence@localhost:5432/adherence
ADHERENCE_REDIS_URL=redis://localhost:6379/0
ADHERENCE_MLFLOW_TRACKING_URI=http://localhost:5000
ADHERENCE_MODEL_REGISTRY=./models/registry

# Drift
ADHERENCE_DRIFT_WEBHOOK_URL=
ADHERENCE_DRIFT_PSI_THRESHOLD=0.2

# Med-Tracker integration
MEDTRACKER_BASE_URL=
MEDTRACKER_API_KEY=

# Telemetry
OTEL_SERVICE_NAME=adherence-ml
OTEL_EXPORTER_OTLP_ENDPOINT=
